#!/usr/bin/env bash
set -euo pipefail

# ─── Orkestr Self-Hosted Deploy Script ───────────────────────────
# Usage: ./bin/orkestr <command>

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
COMPOSE_FILE="$PROJECT_DIR/docker-compose.prod.yml"
ENV_FILE="$PROJECT_DIR/.env"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log()   { echo -e "${BLUE}[orkestr]${NC} $1"; }
ok()    { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
fail()  { echo -e "${RED}[✗]${NC} $1"; exit 1; }

# ─── Commands ────────────────────────────────────────────────────

cmd_deploy() {
    log "Deploying Orkestr..."

    check_prerequisites
    check_env

    log "Building production images..."
    docker compose -f "$COMPOSE_FILE" build --pull

    log "Starting services..."
    docker compose -f "$COMPOSE_FILE" up -d

    log "Waiting for database..."
    wait_for_service mariadb 30

    log "Running migrations..."
    docker compose -f "$COMPOSE_FILE" exec -T app php artisan migrate --force

    log "Generating app key if needed..."
    docker compose -f "$COMPOSE_FILE" exec -T app php artisan key:generate --force --no-interaction 2>/dev/null || true

    log "Clearing caches..."
    docker compose -f "$COMPOSE_FILE" exec -T app php artisan optimize:clear 2>/dev/null || true

    echo ""
    ok "Orkestr deployed successfully!"
    echo ""
    log "Access at: http://localhost:${APP_PORT:-8000}"
    log "Admin panel: http://localhost:${APP_PORT:-8000}/admin"
    echo ""
    log "Run 'bin/orkestr status' to check health."
}

cmd_start() {
    log "Starting Orkestr..."
    docker compose -f "$COMPOSE_FILE" up -d
    ok "Orkestr started."
}

cmd_stop() {
    log "Stopping Orkestr..."
    docker compose -f "$COMPOSE_FILE" down
    ok "Orkestr stopped."
}

cmd_restart() {
    log "Restarting Orkestr..."
    docker compose -f "$COMPOSE_FILE" restart
    ok "Orkestr restarted."
}

cmd_status() {
    log "Orkestr Service Status"
    echo ""
    docker compose -f "$COMPOSE_FILE" ps
    echo ""

    log "Health checks..."
    local health_url="http://localhost:${APP_PORT:-8000}/api/health"
    if curl -sf "$health_url" > /dev/null 2>&1; then
        ok "API is healthy"
    else
        warn "API is not responding at $health_url"
    fi
}

cmd_logs() {
    local service="${1:-}"
    if [ -n "$service" ]; then
        docker compose -f "$COMPOSE_FILE" logs -f "$service"
    else
        docker compose -f "$COMPOSE_FILE" logs -f
    fi
}

cmd_upgrade() {
    log "Upgrading Orkestr..."

    log "Creating backup before upgrade..."
    docker compose -f "$COMPOSE_FILE" exec -T app php artisan orkestr:backup || warn "Backup failed, continuing..."

    log "Pulling latest images..."
    docker compose -f "$COMPOSE_FILE" pull

    log "Rebuilding..."
    docker compose -f "$COMPOSE_FILE" build --pull

    log "Restarting services..."
    docker compose -f "$COMPOSE_FILE" up -d

    log "Waiting for database..."
    wait_for_service mariadb 30

    log "Running migrations..."
    docker compose -f "$COMPOSE_FILE" exec -T app php artisan migrate --force

    log "Clearing caches..."
    docker compose -f "$COMPOSE_FILE" exec -T app php artisan optimize:clear 2>/dev/null || true

    ok "Orkestr upgraded successfully!"
}

cmd_backup() {
    log "Creating backup..."
    docker compose -f "$COMPOSE_FILE" exec -T app php artisan orkestr:backup
}

cmd_restore() {
    local path="${1:-}"
    if [ -z "$path" ]; then
        fail "Usage: bin/orkestr restore <backup-file.zip>"
    fi
    log "Restoring from $path..."
    docker compose -f "$COMPOSE_FILE" exec -T app php artisan orkestr:restore "$path"
}

cmd_shell() {
    docker compose -f "$COMPOSE_FILE" exec app sh
}

cmd_init_env() {
    if [ -f "$ENV_FILE" ]; then
        warn ".env file already exists. Use --force to overwrite."
        if [ "${1:-}" != "--force" ]; then
            exit 0
        fi
    fi

    log "Generating production .env file..."

    local app_key
    app_key=$(openssl rand -base64 32 2>/dev/null || head -c 32 /dev/urandom | base64)
    local db_password
    db_password=$(openssl rand -hex 16 2>/dev/null || head -c 16 /dev/urandom | xxd -p)
    local db_root_password
    db_root_password=$(openssl rand -hex 16 2>/dev/null || head -c 16 /dev/urandom | xxd -p)

    cat > "$ENV_FILE" <<ENVEOF
# ─── Orkestr Production Configuration ─────────────────────────
# Generated by: bin/orkestr init-env

APP_NAME=Orkestr
APP_ENV=production
APP_KEY=base64:${app_key}
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_PORT=8000

# Database
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=orkestr
DB_USERNAME=orkestr
DB_PASSWORD=${db_password}
DB_ROOT_PASSWORD=${db_root_password}

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# LLM Providers (configure at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434

# Projects directory (bind-mounted into container)
PROJECTS_HOST_PATH=./projects
PROJECTS_BASE_PATH=/projects

# SPA URL (for CORS — set to your domain in production)
APP_SPA_URL=http://localhost:5173

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning

# Security
BCRYPT_ROUNDS=12
ENVEOF

    ok ".env file generated at $ENV_FILE"
    warn "Review and configure your API keys before deploying."
}

# ─── Helpers ─────────────────────────────────────────────────────

check_prerequisites() {
    command -v docker >/dev/null 2>&1 || fail "Docker is not installed."
    command -v docker compose version >/dev/null 2>&1 || docker compose version >/dev/null 2>&1 || fail "Docker Compose is not available."
    ok "Prerequisites met (Docker + Compose)"
}

check_env() {
    if [ ! -f "$ENV_FILE" ]; then
        warn "No .env file found. Generating one..."
        cmd_init_env
    fi

    # Source .env for variable expansion
    set -a
    source "$ENV_FILE" 2>/dev/null || true
    set +a

    # Validate required vars
    local missing=()
    [ -z "${DB_PASSWORD:-}" ] && missing+=("DB_PASSWORD")
    [ -z "${DB_ROOT_PASSWORD:-}" ] && missing+=("DB_ROOT_PASSWORD")

    if [ ${#missing[@]} -gt 0 ]; then
        fail "Missing required env vars: ${missing[*]}"
    fi

    ok "Environment validated"
}

wait_for_service() {
    local service=$1
    local timeout=${2:-30}
    local count=0

    while [ $count -lt $timeout ]; do
        if docker compose -f "$COMPOSE_FILE" exec -T "$service" healthcheck.sh --connect 2>/dev/null; then
            ok "$service is ready"
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done

    warn "$service not ready after ${timeout}s, continuing anyway..."
}

cmd_help() {
    cat <<HELPEOF

  ${BLUE}Orkestr${NC} — Self-Hosted Agent Orchestration

  Usage: bin/orkestr <command> [args]

  ${GREEN}Deployment:${NC}
    deploy          Build and start all services (first-time or redeploy)
    init-env        Generate a production .env file
    upgrade         Pull latest, migrate, restart

  ${GREEN}Lifecycle:${NC}
    start           Start all services
    stop            Stop all services
    restart         Restart all services
    status          Show service status and health

  ${GREEN}Maintenance:${NC}
    backup          Create an instance backup
    restore <file>  Restore from a backup file
    logs [service]  Tail logs (optionally for a specific service)
    shell           Open a shell in the app container

  ${GREEN}Help:${NC}
    help            Show this help message

HELPEOF
}

# ─── Main ────────────────────────────────────────────────────────

case "${1:-help}" in
    deploy)     cmd_deploy ;;
    start)      cmd_start ;;
    stop)       cmd_stop ;;
    restart)    cmd_restart ;;
    status)     cmd_status ;;
    logs)       shift; cmd_logs "$@" ;;
    upgrade)    cmd_upgrade ;;
    backup)     cmd_backup ;;
    restore)    shift; cmd_restore "$@" ;;
    shell)      cmd_shell ;;
    init-env)   shift; cmd_init_env "$@" ;;
    help|--help|-h) cmd_help ;;
    *)          fail "Unknown command: $1. Run 'bin/orkestr help' for usage." ;;
esac
